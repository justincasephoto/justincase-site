---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404" description="Page not found" lang="en">
  <div class="not-found section container--narrow">
    <p class="eyebrow">Error</p>
    <h1 class="not-found-heading">404</h1>
    <p class="not-found-body">This frame is empty.</p>
    <a href="/en/" class="btn btn--accent">Return Home</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    padding-top: calc(var(--nav-h) + 5rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  .not-found-heading {
    font-family: var(--f-serif);
    font-size: clamp(5rem, 20vw, 12rem);
    font-weight: 300;
    line-height: 1;
    color: var(--c-text-dim);
  }
  .not-found-body {
    font-size: 0.85rem;
    color: var(--c-text-muted);
    letter-spacing: 0.1em;
  }
</style>
