---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

interface Props { lang: string; }
const { lang } = Astro.props;
const ui = t(lang);
const base = `/${lang}`;
---

<BaseLayout title={ui.contact.title} description={ui.contact.description} {lang}>
  <div class="contact-page section container--narrow">
    <p class="eyebrow">{lang === 'pl' ? 'Kontakt' : 'Get in touch'}</p>
    <h1 class="section-title">{ui.contact.heading}</h1>
    <div class="divider"></div>

    <div class="contact-list">
      <div class="contact-item">
        <span class="contact-label">Email</span>
        <a href={`mailto:${ui.contact.email}`} class="contact-value contact-link">
          {ui.contact.email}
        </a>
      </div>
      <div class="contact-item">
        <span class="contact-label">Instagram</span>
        <a href={ui.contact.instagramUrl} target="_blank" rel="noopener noreferrer" class="contact-value contact-link">
          {ui.contact.instagram}
        </a>
      </div>
      <div class="contact-item">
        <span class="contact-label">{lang === 'pl' ? 'Lokalizacja' : 'Location'}</span>
        <span class="contact-value">{ui.contact.location}</span>
      </div>
    </div>

    <div class="contact-booking-cta">
      <p class="contact-booking-text">
        {ui.contact.bookingCta}
        {' '}
        <a href={`${base}/booking`} class="contact-booking-link">{ui.contact.bookingLink}</a>
        {lang === 'en' ? '.' : '.'}
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-page { padding-top: calc(var(--nav-h) + 3rem); }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 1rem;
  }
  .contact-item {
    display: grid;
    grid-template-columns: 8rem 1fr;
    align-items: baseline;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--c-border);
  }
  .contact-item:first-child { border-top: 1px solid var(--c-border); }
  .contact-label {
    font-size: 0.63rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-text-dim);
  }
  .contact-value {
    font-family: var(--f-serif);
    font-size: 1.1rem;
    font-weight: 300;
    color: var(--c-text);
  }
  .contact-link { transition: color var(--t-fast); }
  .contact-link:hover { color: var(--c-accent); }

  .contact-booking-cta {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--c-border);
  }
  .contact-booking-text {
    font-size: 0.8rem;
    color: var(--c-text-muted);
  }
  .contact-booking-link {
    color: var(--c-accent);
    transition: opacity var(--t-fast);
  }
  .contact-booking-link:hover { opacity: 0.75; }

  @media (max-width: 480px) {
    .contact-item { grid-template-columns: 1fr; gap: 0.35rem; }
  }
</style>
