---
import { t } from '../i18n/utils';

interface Props {
  lang: string;
  variant?: 'wide' | 'compact';
}
const { lang, variant = 'wide' } = Astro.props;
const ui = t(lang);
const base = `/${lang}`;
---

<a class:list={['booking-banner', `booking-banner--${variant}`]} href={`${base}/booking`} aria-label={`${ui.bookingBanner.text} ${ui.bookingBanner.cta}`}>
  <span class="booking-banner-shimmer" aria-hidden="true"></span>
  <span class="booking-banner-inner">
    <span class="booking-banner-text">{ui.bookingBanner.text}</span>
    <span class="booking-banner-cta">{ui.bookingBanner.cta}</span>
  </span>
</a>

<style>
  .booking-banner {
    position: relative;
    display: block;
    overflow: hidden;
    border: 1px solid var(--c-border-acc);
    border-radius: 2px;
    background:
      linear-gradient(90deg,
        rgba(30, 22, 12, 0.65) 0%,
        rgba(48, 34, 15, 0.9) 50%,
        rgba(30, 22, 12, 0.65) 100%);
    color: var(--c-text);
    text-decoration: none;
    transition: transform var(--t-mid), border-color var(--t-mid), box-shadow var(--t-mid);
    box-shadow:
      0 0 0 rgba(200, 169, 122, 0),
      inset 0 0 40px rgba(200, 169, 122, 0.06);
  }

  .booking-banner:hover {
    border-color: var(--c-accent);
    transform: translateY(-2px);
    box-shadow:
      0 10px 40px -10px rgba(200, 169, 122, 0.35),
      inset 0 0 60px rgba(200, 169, 122, 0.12);
  }

  .booking-banner-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      110deg,
      transparent 0%,
      transparent 35%,
      rgba(212, 185, 138, 0.28) 48%,
      rgba(232, 205, 158, 0.5) 50%,
      rgba(212, 185, 138, 0.28) 52%,
      transparent 65%,
      transparent 100%
    );
    background-size: 250% 100%;
    background-position: -60% 0;
    animation: booking-shimmer 3.6s ease-in-out infinite;
    pointer-events: none;
    mix-blend-mode: screen;
  }

  @keyframes booking-shimmer {
    0%   { background-position: -60% 0; }
    45%  { background-position: 160% 0; }
    100% { background-position: 160% 0; }
  }

  .booking-banner-inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    padding: 1.15rem 1.5rem;
  }

  .booking-banner-text {
    font-family: var(--f-serif);
    font-style: italic;
    font-size: clamp(0.95rem, 2.4vw, 1.25rem);
    font-weight: 400;
    color: var(--c-text);
    letter-spacing: 0.005em;
    line-height: 1.25;
  }

  .booking-banner-cta {
    font-family: var(--f-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-accent);
    white-space: nowrap;
    padding-left: 0.75rem;
    border-left: 1px solid rgba(200, 169, 122, 0.35);
    flex-shrink: 0;
  }

  .booking-banner--compact .booking-banner-inner {
    padding: 0.85rem 1.1rem;
    gap: 0.85rem;
  }
  .booking-banner--compact .booking-banner-text {
    font-size: clamp(0.85rem, 2vw, 1rem);
  }

  @media (max-width: 520px) {
    .booking-banner-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.6rem;
    }
    .booking-banner-cta {
      padding-left: 0;
      border-left: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .booking-banner-shimmer { animation: none; }
    .booking-banner:hover { transform: none; }
  }
</style>
